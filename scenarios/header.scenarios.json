      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_visible",
          "selector": "header a img, header .logo, header [class*='logo']"
        },
        { "action": "expect_visible", "selector": "a[href='/cart']" }
      ]
    },

    {
      "id": "TC_HDR_M_001",
      "name": "[Mobile] Header hiển thị nhất quán trên tất cả pages",
      "tags": ["mobile", "smoke", "regression"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/collections/all" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/pages/about-us" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/pages/support" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/cart" },
        { "action": "expect_visible", "selector": "header, [class*='header']" }
      ]
    },

    {
      "id": "TC_HDR_M_002",
      "name": "[Mobile] Header nằm ở top page (position fixed/sticky)",
      "tags": ["mobile", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_css_property",
          "selector": "header, [class*='header']",
          "property": "position",
          "value_contains": "fixed|sticky"
        }
      ]
    },

    {
      "id": "TC_HDR_M_003",
      "name": "[Mobile] Header sticky - vẫn hiển thị sau khi scroll",
      "tags": ["mobile", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        { "action": "scroll_by", "x": 0, "y": 800 },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        {
          "action": "expect_in_viewport",
          "selector": "header, [class*='header']"
        }
      ]
    },

    {
      "id": "TC_HDR_M_004",
      "name": "[Mobile] Burger icon hiển thị thay cho thanh menu ngang",
      "tags": ["mobile", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_visible",
          "selector": "button[class*='burger'], button[class*='menu'], [class*='hamburger'], [aria-label*='menu'], [aria-label*='Menu']"
        }
      ]
    },

    {
      "id": "TC_HDR_M_005",
      "name": "[Mobile] Click burger icon mở overlay menu full screen",
      "tags": ["mobile", "smoke", "burger"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        {
          "action": "click",
          "selector": "button[class*='burger'], button[class*='menu'], [class*='hamburger'], [aria-label*='menu'], [aria-label*='Menu']"
        },
        { "action": "wait", "ms": 500 },
        {
          "action": "expect_visible",
          "selector": "[class*='overlay'], [class*='mobile-menu'], [class*='drawer'], nav[class*='mobile']"
        }
      ]
    },

    {
      "id": "TC_HDR_M_006",
      "name": "[Mobile] Click X đóng overlay thành công",
      "tags": ["mobile", "smoke", "burger"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        {
          "action": "click",
          "selector": "button[class*='burger'], button[class*='menu'], [class*='hamburger'], [aria-label*='menu']"
        },
        { "action": "wait", "ms": 500 },
        {
          "action": "click",
          "selector": "button[aria-label*='close'], button[class*='close'], [class*='overlay'] button.close, [class*='menu'] button[class*='close']"
        },
        { "action": "wait", "ms": 500 },
        {
          "action": "expect_not_visible",
          "selector": "[class*='overlay'], [class*='mobile-menu'], [class*='drawer']"
        }
      ]
    },

    {
      "id": "TC_HDR_M_007",
      "name": "[Mobile] Click menu item trong overlay - overlay tự đóng và navigate đúng URL",
      "tags": ["mobile", "burger", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        {
          "action": "click",
          "selector": "button[class*='burger'], button[class*='menu'], [class*='hamburger'], [aria-label*='menu']"
        },
        { "action": "wait", "ms": 500 },
        {
          "action": "click",
          "selector": "[class*='overlay'] a[href='/collections/all'], [class*='mobile-menu'] a[href='/collections/all'], nav a[href='/collections/all']"
        },
        { "action": "expect_url_contains", "url": "/collections/all" },
        {
          "action": "expect_not_visible",
          "selector": "[class*='overlay'], [class*='mobile-menu'], [class*='drawer']"
        }
      ]
    },

