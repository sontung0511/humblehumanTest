      "id": "TC_HDR_M_010",
      "name": "[Mobile] Click current page menu (Home → click Home) - không reload bất thường",
      "tags": ["mobile", "navigation", "regression"],
      "steps": [
        { "action": "set_viewport", "width": 390, "height": 844 },
        { "action": "navigate", "url": "/" },
        {
          "action": "click",
          "selector": "button[class*='burger'], button[class*='menu'], [class*='hamburger'], [aria-label*='menu']"
