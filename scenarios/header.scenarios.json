{
  "suiteName": "Global Header - Desktop & Mobile",
  "baseUrl": "https://humblehuman.vn",
  "_menu_config": {
    "Home": "/",
    "Shop": "/collections/all",
    "Campaign": "/collections/all",
    "About": "/pages/about-us",
    "Support": "/pages/support",
    "Cart": "/cart"
  },
  "scenarios": [
    {
      "id": "TC_HDR_D_001",
      "name": "[Desktop] Header hiển thị nhất quán trên tất cả pages",
      "tags": ["desktop", "smoke", "regression"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/collections/all" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/collections/all" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/pages/about-us" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/pages/support" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/cart" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "navigate", "url": "/search" },
        { "action": "expect_visible", "selector": "header, [class*='header']" }
      ]
    },

    {
      "id": "TC_HDR_D_002",
      "name": "[Desktop] Header nằm ở top page (position fixed/sticky, top: 0)",
      "tags": ["desktop", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_css_property",
          "selector": "header, [class*='header']",
          "property": "position",
          "value_contains": "fixed|sticky"
        },
        {
          "action": "expect_css_property",
          "selector": "header, [class*='header']",
          "property": "top",
          "value_contains": "0"
        }
      ]
    },

    {
      "id": "TC_HDR_D_003",
      "name": "[Desktop] Header sticky - vẫn hiển thị sau khi scroll xuống",
      "tags": ["desktop", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "scroll_by", "x": 0, "y": 800 },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        {
          "action": "expect_in_viewport",
          "selector": "header, [class*='header']"
        }
      ]
    },

    {
      "id": "TC_HDR_D_004",
      "name": "[Desktop] Header không bị content che (z-index cao hơn content)",
      "tags": ["desktop", "ui", "regression"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "scroll_by", "x": 0, "y": 300 },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        {
          "action": "expect_css_property",
          "selector": "header, [class*='header']",
          "property": "z-index",
          "value_gte": "10"
        }
      ]
    },

    {
      "id": "TC_HDR_D_005",
      "name": "[Desktop] Full navigation menu hiển thị đầy đủ (ngang)",
      "tags": ["desktop", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_visible",
          "selector": "nav a[href='/'], nav a[href='/collections/all']"
        },
        { "action": "expect_text_visible", "value": "Shop" },
        { "action": "expect_text_visible", "value": "About" },
        { "action": "expect_text_visible", "value": "Support" }
      ]
    },

    {
      "id": "TC_HDR_D_006",
      "name": "[Desktop] Click menu 'Home' điều hướng về trang chủ",
      "tags": ["desktop", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/collections/all" },
        {
          "action": "click",
          "selector": "nav a[href='/'], header a[href='/']"
        },
        { "action": "expect_url", "url": "https://humblehuman.vn/" }
      ]
    },

    {
      "id": "TC_HDR_D_007",
      "name": "[Desktop] Click menu 'Shop' điều hướng đến /collections/all",
      "tags": ["desktop", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "click",
          "selector": "nav a[href='/collections/all'], header a[href='/collections/all']"
        },
        { "action": "expect_url_contains", "url": "/collections/all" }
      ]
    },

    {
      "id": "TC_HDR_D_008",
      "name": "[Desktop] Click menu 'Campaign' điều hướng đúng URL",
      "tags": ["desktop", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "click_text", "text": "Campaign" },
        { "action": "expect_url_contains", "url": "/collections/all" }
      ]
    },

    {
      "id": "TC_HDR_D_009",
      "name": "[Desktop] Click menu 'About' điều hướng đến /pages/about-us",
      "tags": ["desktop", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "click_text", "text": "About" },
        { "action": "expect_url_contains", "url": "/pages/about" }
      ]
    },

    {
      "id": "TC_HDR_D_010",
      "name": "[Desktop] Click menu 'Support' điều hướng đến /pages/support",
      "tags": ["desktop", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "click_text", "text": "Support" },
        { "action": "expect_url_contains", "url": "/pages/support" }
      ]
    },

    {
      "id": "TC_HDR_D_011",
      "name": "[Desktop] Click menu 'Cart' điều hướng đến /cart",
      "tags": ["desktop", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "click", "selector": "a[href='/cart']" },
        { "action": "expect_url_contains", "url": "/cart" }
      ]
    },

    {
      "id": "TC_HDR_D_012",
      "name": "[Desktop] Click current page menu - không reload bất thường (ở Home click Home)",
      "tags": ["desktop", "navigation", "regression"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_no_reload_on_click",
          "selector": "nav a[href='/'], header a[href='/']"
        }
      ]
    },

    {
      "id": "TC_HDR_D_013",
      "name": "[Desktop] Click current page menu - không reload bất thường (ở Shop click Shop)",
      "tags": ["desktop", "navigation", "regression"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/collections/all" },
        {
          "action": "click",
          "selector": "nav a[href='/collections/all'], header a[href='/collections/all']"
        },
        { "action": "expect_url_contains", "url": "/collections/all" },
        { "action": "expect_visible", "selector": "header, [class*='header']" }
      ]
    },

    {
      "id": "TC_HDR_D_014",
      "name": "[Desktop] Menu hiển thị đúng theo config order_number",
      "tags": ["desktop", "regression", "config"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_menu_order",
          "items": ["Home", "Shop", "Campaign", "About", "Support"]
        }
      ]
    },

    {
      "id": "TC_HDR_D_015",
      "name": "[Desktop] Chỉ hiển thị menu item is_active = true",
      "tags": ["desktop", "regression", "config"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_visible",
          "selector": "nav a[href='/'], nav a[href='/collections/all']"
        }
      ]
    },

    {
      "id": "TC_HDR_D_016",
      "name": "[Desktop] Logo hiển thị chính giữa header",
      "tags": ["desktop", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_visible",
          "selector": "header a img, header .logo, header [class*='logo']"
        },
        {
          "action": "expect_center_aligned",
          "selector": "header a img, header .logo, header [class*='logo']"
        }
      ]
    },

    {
      "id": "TC_HDR_D_017",
      "name": "[Desktop] Click logo (HUMBLE HUMAN) từ trang khác điều hướng về homepage",
      "tags": ["desktop", "navigation"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/collections/all" },
        {
          "action": "click",
          "selector": "header a[href='/'] img, header a[href='/'].logo, header [class*='logo'] a"
        },
        { "action": "expect_url", "url": "https://humblehuman.vn/" }
      ]
    },

    {
      "id": "TC_HDR_D_018",
      "name": "[Desktop] Cart icon hiển thị đúng vị trí top-right",
      "tags": ["desktop", "smoke", "ui"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "expect_visible", "selector": "a[href='/cart']" }
      ]
    },

    {
      "id": "TC_HDR_D_019",
      "name": "[Desktop] Click cart icon điều hướng đến cart page",
      "tags": ["desktop", "smoke", "cart"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "click", "selector": "a[href='/cart']" },
        { "action": "expect_url_contains", "url": "/cart" }
      ]
    },

    {
      "id": "TC_HDR_D_020",
      "name": "[Desktop] Cart badge hiển thị đúng số lượng sản phẩm trong giỏ",
      "tags": ["desktop", "cart", "regression"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        {
          "action": "navigate",
          "url": "/products/nhan-ban-tu-hum-effortless-long-sleeve-shirt-muslin-cotton-black"
        },
        { "action": "click_text", "text": "THÊM VÀO GIỎ" },
        { "action": "wait_for_url", "url": "/cart" },
        { "action": "navigate", "url": "/" },
        { "action": "expect_text_visible", "value": "1" }
      ]
    },

    {
      "id": "TC_HDR_D_021",
      "name": "[Desktop] Theme light - text/icon/logo hiển thị đúng (readable)",
      "tags": ["desktop", "ui", "theme"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        {
          "action": "expect_visible",
          "selector": "header a img, header .logo"
        },
        { "action": "expect_visible", "selector": "a[href='/cart']" },
        { "action": "expect_visible", "selector": "a[href='/search']" }
      ]
    },

    {
      "id": "TC_HDR_D_022",
      "name": "[Desktop] Search icon - tìm kiếm đúng kết quả",
      "tags": ["desktop", "search"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/" },
        { "action": "click", "selector": "a[href='/search']" },
        { "action": "expect_url_contains", "url": "/search" },
        { "action": "fill", "selector": "input[name='q']", "value": "áo" },
        {
          "action": "press_key",
          "selector": "input[name='q']",
          "key": "Enter"
        },
        {
          "action": "expect_count",
          "selector": "a[href*='/products/']",
          "count": 1,
          "operator": "gte"
        }
      ]
    },

    {
      "id": "TC_HDR_D_EDGE_001",
      "name": "[Desktop][Edge] URL menu lỗi - UI không crash, header vẫn ổn định",
      "tags": ["desktop", "edge"],
      "steps": [
        { "action": "set_viewport", "width": 1280, "height": 720 },
        { "action": "navigate", "url": "/collections/non-existent-page-404" },
        { "action": "expect_visible", "selector": "header, [class*='header']" },
        { "action": "expect_visible", "selector": "a[href='/cart']" }
      ]
    },

    {
      "id": "TC_HDR_D_EDGE_002",
      "name": "[Desktop][Edge] Logo quá lớn - Logo tự scale fit, không vỡ header",
