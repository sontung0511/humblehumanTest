        {
          "action": "expect_no_overflow",
          "selector": "nav, header nav"
        }
      ]
    },

    {
      "id": "TC_HDR_D_EDGE_004",
      "name": "[Desktop][Edge] Không có menu item - Header vẫn hiển thị với logo và cart",
